---
interface Props {
  title: string;
  description: string;
  icon: string;
  href: string;
}
const { title, description, icon, href } = Astro.props;
---

<div class="bg-white rounded-xl shadow-md hover:shadow-xl transition-shadow p-6 flex flex-col gap-4 border border-gray-100">
  <div class="w-14 h-14 bg-primary/10 rounded-xl flex items-center justify-center text-3xl">{icon}</div>
  <h3 class="text-xl font-bold text-primary">{title}</h3>
  <p class="text-gray-600 leading-relaxed flex-1">{description}</p>
  <a href={href} class="text-accent font-semibold hover:underline flex items-center gap-1">
    Learn more
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
    </svg>
  </a>
</div>
