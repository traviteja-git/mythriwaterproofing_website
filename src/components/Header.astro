---
const base = import.meta.env.BASE_URL;
const nav = [
  { label: 'Home',     href: `${base}` },
  { label: 'About',    href: `${base}about` },
  { label: 'Services', href: `${base}services` },
  { label: 'Gallery',  href: `${base}gallery` },
  { label: 'Contact',  href: `${base}contact` },
];
---

<!-- Utility bar -->
<div class="bg-primary text-white/70 text-sm py-2 px-4">
  <div class="max-w-6xl mx-auto flex flex-wrap items-center justify-between gap-2">
    <div class="flex items-center gap-3">
      <a href="tel:+919550667148" class="flex items-center gap-1.5 hover:text-white transition-colors">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        +91 95506 67148
      </a>
      <span class="text-white/30">|</span>
      <a href="tel:+919052945434" class="flex items-center gap-1.5 hover:text-white transition-colors">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        +91 90529 45434
      </a>
    </div>
    <a href="https://www.instagram.com/mythriwaterproofing" target="_blank" rel="noopener"
      class="flex items-center gap-1.5 hover:text-white transition-colors">
      <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
      @mythriwaterproofing
    </a>
  </div>
</div>

<!-- Main header -->
<header class="bg-white/95 backdrop-blur-sm border-b border-line shadow-sm sticky top-0 z-50">
  <div class="max-w-6xl mx-auto px-4 py-3 flex items-center justify-between">
    <a href={`${base}`} class="flex items-center gap-3">
      <img src={`${base}logo.png`} alt="Mythri Waterproofing" class="h-11 w-11 object-contain shrink-0" />
      <div>
        <div class="font-display font-extrabold text-ink text-base leading-tight">Mythri Waterproofing</div>
        <div class="text-accent text-xs font-medium">Trusted. Tested. Proven.</div>
      </div>
    </a>

    <nav class="hidden md:flex items-center gap-6">
      {nav.map(({ label, href }) => (
        <a href={href} class="text-ink-mid hover:text-primary font-medium transition-colors text-sm">{label}</a>
      ))}
      <a href="tel:+919550667148"
        class="flex items-center gap-2 bg-accent hover:bg-accent-dark text-white px-5 py-2.5 rounded-[13px] font-bold transition-colors text-sm shadow-[0_8px_24px_rgba(220,31,38,.3)]">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        Get a Quote
      </a>
    </nav>

    <button id="menu-toggle" class="md:hidden text-ink p-1" aria-label="Toggle menu">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </div>

  <div id="mobile-menu" class="hidden md:hidden bg-white border-t border-line px-4 pb-4">
    {nav.map(({ label, href }) => (
      <a href={href} class="block py-3 text-ink-mid hover:text-primary font-medium border-b border-line text-sm">{label}</a>
    ))}
    <div class="mt-4 flex flex-col gap-2">
      <a href="tel:+919550667148" class="block text-center bg-accent text-white px-4 py-3 rounded-[13px] font-bold text-sm">
        Call: +91 95506 67148
      </a>
      <a href="https://wa.me/919550667148?text=Hi%2C%20I%20need%20waterproofing%20services" target="_blank" rel="noopener"
        class="block text-center text-white px-4 py-3 rounded-[13px] font-bold text-sm" style="background:#25D366">
        WhatsApp Us
      </a>
    </div>
  </div>
</header>

<script>
  document.getElementById('menu-toggle')?.addEventListener('click', () => {
    document.getElementById('mobile-menu')?.classList.toggle('hidden');
  });
</script>
