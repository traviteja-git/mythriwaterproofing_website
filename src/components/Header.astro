---
const base = import.meta.env.BASE_URL;
const nav = [
  { label: 'Home',     href: `${base}` },
  { label: 'About',    href: `${base}about` },
  { label: 'Services', href: `${base}services` },
  { label: 'Gallery',  href: `${base}gallery` },
  { label: 'Contact',  href: `${base}contact` },
];
---

<!-- Utility bar -->
<div class="bg-primary-dark text-white/60 text-sm py-2 px-4">
  <div class="max-w-6xl mx-auto flex flex-wrap items-center justify-between gap-2">
    <div class="flex items-center gap-5">
      <a href="tel:+919550667148" class="flex items-center gap-1.5 hover:text-white transition-colors">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        +91 95506 67148
      </a>
      <a href="mailto:mythriwaterproofingworks@gmail.com" class="hidden sm:flex items-center gap-1.5 hover:text-white transition-colors">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
        mythriwaterproofingworks@gmail.com
      </a>
    </div>
    <a href="https://wa.me/919550667148?text=Hi%2C%20I%20need%20waterproofing%20services" target="_blank" rel="noopener"
      class="flex items-center gap-1.5 text-green-400 hover:text-green-300 font-semibold transition-colors">
      <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/></svg>
      WhatsApp
    </a>
  </div>
</div>

<!-- Main header -->
<header class="bg-primary shadow-lg sticky top-0 z-50">
  <div class="max-w-6xl mx-auto px-4 py-3 flex items-center justify-between">
    <a href={`${base}`} class="flex items-center gap-3">
      <img src={`${base}logo.png`} alt="Mythri Water Proofing Solutions" class="h-12 w-12 object-contain shrink-0" />
      <div>
        <div class="font-display font-black text-white text-lg leading-tight tracking-tight">Mythri Waterproofing</div>
        <div class="text-water-light text-xs font-medium">Trusted. Tested. Proven.</div>
      </div>
    </a>

    <nav class="hidden md:flex items-center gap-6">
      {nav.map(({ label, href }) => (
        <a href={href} class="text-white/70 hover:text-white font-medium transition-colors text-sm">{label}</a>
      ))}
      <a href="tel:+919550667148" class="flex items-center gap-2 bg-accent hover:bg-accent-dark text-white px-5 py-2.5 rounded-xl font-bold transition-colors text-sm shadow-[0_6px_20px_rgba(220,31,38,.4)]">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        Free Quote
      </a>
    </nav>

    <button id="menu-toggle" class="md:hidden text-white p-1" aria-label="Toggle menu">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </div>

  <div id="mobile-menu" class="hidden md:hidden bg-primary-light px-4 pb-4 border-t border-white/10">
    {nav.map(({ label, href }) => (
      <a href={href} class="block py-3 text-white/70 hover:text-white font-medium border-b border-white/10 text-sm">{label}</a>
    ))}
    <div class="mt-4 flex flex-col gap-2">
      <a href="tel:+919550667148" class="block text-center bg-accent text-white px-4 py-3 rounded-xl font-bold text-sm">
        Call: +91 95506 67148
      </a>
      <a href="https://wa.me/919550667148?text=Hi%2C%20I%20need%20waterproofing%20services" target="_blank" rel="noopener"
        class="block text-center text-white px-4 py-3 rounded-xl font-bold text-sm" style="background:#25D366">
        WhatsApp Us
      </a>
    </div>
  </div>
</header>

<script>
  document.getElementById('menu-toggle')?.addEventListener('click', () => {
    document.getElementById('mobile-menu')?.classList.toggle('hidden');
  });
</script>
