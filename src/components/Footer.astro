---
const base = import.meta.env.BASE_URL;
---

<footer class="bg-primary text-blue-100 mt-16">
  <div class="max-w-6xl mx-auto px-4 py-12 grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-8">

    <!-- Brand -->
    <div class="md:col-span-1">
      <div class="flex items-center gap-2 mb-3">
        <img src={`${base}logo.png`} alt="Mythri Water Proofing Solutions" class="h-10 w-10 rounded-full object-cover bg-white shrink-0" />
        <div class="text-white font-bold">Mythri Waterproofing</div>
      </div>
      <p class="text-sm leading-relaxed mb-4">Trusted waterproofing solutions for homes and buildings across Hyderabad. 20+ years. 500+ projects.</p>
      <!-- Social -->
      <div class="flex gap-3">
        <a href="https://www.instagram.com/mythriwaterproofing" target="_blank" rel="noopener" aria-label="Instagram"
          class="w-8 h-8 bg-white/10 hover:bg-accent rounded-lg flex items-center justify-center transition-colors">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
        </a>
        <a href="https://wa.me/919876543210" target="_blank" rel="noopener" aria-label="WhatsApp"
          class="w-8 h-8 bg-white/10 hover:bg-green-600 rounded-lg flex items-center justify-center transition-colors">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
        </a>
      </div>
    </div>

    <!-- Quick Links -->
    <div>
      <div class="text-white font-semibold mb-3">Quick Links</div>
      <ul class="space-y-2 text-sm">
        {[['Home', ''], ['About', 'about'], ['Services', 'services'], ['Gallery', 'gallery'], ['Contact', 'contact']].map(([label, path]) => (
          <li><a href={`${base}${path}`} class="hover:text-white transition-colors">{label}</a></li>
        ))}
      </ul>
    </div>

    <!-- Services -->
    <div>
      <div class="text-white font-semibold mb-3">Services</div>
      <ul class="space-y-2 text-sm">
        {[
          ['Terrace Waterproofing', 'terrace'],
          ['Bathroom Waterproofing', 'bathroom'],
          ['Wall & Facade', 'wall'],
          ['Water Tank / Sump', 'tank'],
          ['Basement', 'basement'],
          ['Balcony & Podium', 'balcony'],
        ].map(([label, id]) => (
          <li><a href={`${base}services#${id}`} class="hover:text-white transition-colors">{label}</a></li>
        ))}
      </ul>
    </div>

    <!-- Contact -->
    <div>
      <div class="text-white font-semibold mb-3">Contact Us</div>
      <ul class="space-y-3 text-sm">
        <li>
          <a href="tel:+919876543210" class="flex items-start gap-2 hover:text-white transition-colors">
            <svg class="w-4 h-4 mt-0.5 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"/></svg>
            +91 98765 43210
          </a>
        </li>
        <li>
          <a href="https://wa.me/919876543210" target="_blank" rel="noopener" class="flex items-start gap-2 text-green-300 hover:text-green-200 transition-colors">
            <svg class="w-4 h-4 mt-0.5 shrink-0" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
        </li>
        <li class="flex items-start gap-2">
          <svg class="w-4 h-4 mt-0.5 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path d="M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0016 4H4a2 2 0 00-1.997 1.884z"/><path d="M18 8.118l-8 4-8-4V14a2 2 0 002 2h12a2 2 0 002-2V8.118z"/></svg>
          info@mythriwaterproofing.com
        </li>
        <li class="flex items-start gap-2">
          <svg class="w-4 h-4 mt-0.5 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/></svg>
          Hyderabad, Telangana
        </li>
      </ul>
    </div>
  </div>

  <div class="border-t border-primary-light text-center text-xs text-blue-300 py-4 px-4">
    &copy; {new Date().getFullYear()} Mythri Waterproofing. All rights reserved. | Serving Hyderabad, Secunderabad & surrounding areas.
  </div>
</footer>
