---
import BaseLayout from '../layouts/BaseLayout.astro';

const base = import.meta.env.BASE_URL;
---

<BaseLayout title="About Us" description="Learn about Mythri Waterproofing — our story, mission, and the team behind Hyderabad's trusted waterproofing service.">

  <!-- Hero -->
  <section class="bg-gradient-to-br from-primary to-primary-light text-white py-20 px-4 text-center">
    <h1 class="text-4xl md:text-5xl font-extrabold mb-4">About Mythri Waterproofing</h1>
    <p class="text-blue-100 text-lg max-w-2xl mx-auto">A decade of trust, one leak at a time.</p>
  </section>

  <!-- Our Story -->
  <section class="py-20 px-4">
    <div class="max-w-5xl mx-auto grid md:grid-cols-2 gap-12 items-center">
      <div>
        <h2 class="text-3xl font-extrabold text-primary mb-4">Our Story</h2>
        <p class="text-gray-600 leading-relaxed mb-4">
          Mythri Waterproofing was founded with a simple mission: deliver waterproofing solutions that actually work, backed by honest advice and fair pricing. Over 20 years ago, our founder identified a critical gap in the market — homeowners were paying repeatedly for short-term fixes that never addressed root causes.
        </p>
        <p class="text-gray-600 leading-relaxed mb-4">
          We set out to change that by combining the best materials, trained technicians, and a thorough diagnostic approach. Today, we've completed over 500 projects across Hyderabad and have become the go-to waterproofing partner for both residential and commercial clients.
        </p>
        <p class="text-gray-600 leading-relaxed">
          Every project we take on is treated like it's our own home — because we know how much your property means to you.
        </p>
      </div>
      <div class="bg-gradient-to-br from-primary/10 to-accent/10 rounded-2xl p-12 flex items-center justify-center text-8xl">
        🏗️
      </div>
    </div>
  </section>

  <!-- Mission & Values -->
  <section class="bg-gray-50 py-20 px-4">
    <div class="max-w-5xl mx-auto">
      <h2 class="text-3xl font-extrabold text-primary text-center mb-12">Our Mission & Values</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {[
          { icon: '🎯', title: 'Mission', desc: 'To provide lasting waterproofing solutions that protect homes and buildings for years, not months.' },
          { icon: '💎', title: 'Quality', desc: 'We use only premium-grade materials and proven techniques to ensure every job meets our high standards.' },
          { icon: '🤝', title: 'Integrity', desc: 'Transparent pricing, honest assessments, and no upselling — just the right solution for your problem.' },
        ].map(({ icon, title, desc }) => (
          <div class="bg-white rounded-2xl p-8 text-center shadow-md border border-gray-100">
            <div class="text-5xl mb-4">{icon}</div>
            <h3 class="text-xl font-bold text-primary mb-2">{title}</h3>
            <p class="text-gray-600">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Service Area -->
  <section class="py-20 px-4">
    <div class="max-w-5xl mx-auto text-center">
      <h2 class="text-3xl font-extrabold text-primary mb-4">Service Area</h2>
      <p class="text-gray-600 text-lg mb-8 max-w-2xl mx-auto">We serve residential and commercial clients across Greater Hyderabad, including Secunderabad, Gachibowli, Kondapur, Madhapur, Kukatpally, and surrounding areas.</p>
      <div class="bg-primary/5 border border-primary/20 rounded-2xl p-8 inline-block">
        <div class="text-6xl mb-3">📍</div>
        <div class="font-bold text-primary text-lg">Greater Hyderabad, Telangana</div>
        <div class="text-gray-500 text-sm mt-1">Serving all major areas and suburbs</div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-accent py-16 px-4 text-white text-center">
    <h2 class="text-3xl font-extrabold mb-3">Let's Work Together</h2>
    <p class="text-orange-100 text-lg mb-8">Get in touch for a free site inspection and quote.</p>
    <a href={`${base}contact`} class="bg-white text-accent hover:bg-orange-50 font-bold px-10 py-4 rounded-xl text-lg transition-colors">
      Contact Us
    </a>
  </section>

</BaseLayout>
