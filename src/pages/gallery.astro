---

<BaseLayout
  title="Project Gallery — Mythri Waterproofing"
  description="Real waterproofing projects by Mythri Water Proofing Solutions — terrace coating, epoxy tile packing, and brick batting across Hyderabad."
>

  <!-- Hero -->
  <section class="bg-brand text-white py-20 px-4 text-center">
    <p class="text-accent text-xs font-bold uppercase tracking-[2px] mb-3">Our Work Speaks</p>
    <h1 class="font-display text-4xl md:text-5xl font-extrabold mb-4">Project Gallery</h1>
    <p class="text-white/60 text-lg max-w-2xl mx-auto">
      Real jobs. Real results. Browse our completed waterproofing work across Hyderabad and surrounding areas.
    </p>
  </section>

  <!-- Filter + Grid -->
  <section class="py-16 px-4 bg-bg-light">
    <div class="max-w-6xl mx-auto">

      <!-- Filter tabs -->
      <div class="flex flex-wrap gap-3 justify-center mb-10" id="filters">
        {filters.map(({ key, label }, i) => (
          <button
            data-filter={key}
            class={`filter-btn px-5 py-2.5 rounded-full font-semibold border-2 transition-all text-sm ${
              i === 0
                ? 'bg-accent text-white border-accent'
                : 'bg-white text-ink border-line hover:border-accent hover:text-accent'
            }`}
          >
            {label}
          </button>
        ))}
      </div>

      <!-- Grid -->
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-4" id="gallery-grid">
        {projects.map(({ id, category, label, location, img, featured }) => (
          <div
            data-category={category}
            data-featured={featured ? 'true' : 'false'}
            style={featured ? undefined : 'display:none'}
            class="gallery-item group rounded-2xl overflow-hidden shadow-sm hover:shadow-lg transition-all border border-line bg-white"
          >
            <div class="aspect-square overflow-hidden bg-bg-soft">
              <img
                src={img}
                alt={`${label} — ${location}`}
                loading="lazy"
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                onerror="this.parentElement.innerHTML='<div class=\'w-full h-full flex items-center justify-center text-ink-subtle text-xs text-center p-2\'>Photo coming soon</div>'"
              />
            </div>
            <div class="p-3 bg-white">
              <div class="font-bold text-ink text-xs leading-snug">{label}</div>
              <div class="text-ink-subtle text-xs flex items-center gap-1 mt-1">
                <svg class="w-3 h-3 text-accent shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
                {location}
              </div>
            </div>
          </div>
        ))}
      </div>

      <p class="text-center text-ink-subtle text-sm mt-10">More projects added regularly. <a href={`${base}contact`} class="text-accent font-semibold hover:underline">Contact us</a> for a free site visit.</p>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 px-4 text-center" style="background: linear-gradient(135deg, #1A1A1A 0%, #2D0A0A 100%)">
    <h2 class="font-display text-3xl font-extrabold text-white mb-3">Want Results Like These?</h2>
    <p class="text-white/60 text-lg mb-8">Get a free site visit and no-obligation quote today.</p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a href="tel:+919550667148"
        class="flex items-center justify-center gap-2 bg-accent hover:bg-accent-dark text-white font-bold px-8 py-4 rounded-[13px] text-base transition-colors shadow-[0_8px_24px_rgba(204,31,31,.35)]">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        Call Now
      </a>
      <a href="https://wa.me/919550667148?text=Hi%2C%20I%20need%20waterproofing%20services" target="_blank" rel="noopener"
        class="flex items-center justify-center gap-2 text-white font-bold px-8 py-4 rounded-[13px] text-base transition-colors"
        style="background:#25D366">
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/></svg>
        WhatsApp Us
      </a>
    </div>
  </section>

</BaseLayout>

<script>
  const btns = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const items = document.querySelectorAll<HTMLElement>('.gallery-item');

  btns.forEach(btn => {
    btn.addEventListener('click', () => {
      const filter = btn.dataset.filter;

      btns.forEach(b => {
        b.classList.remove('bg-accent', 'text-white', 'border-accent');
        b.classList.add('bg-white', 'text-ink', 'border-line');
      });
      btn.classList.add('bg-accent', 'text-white', 'border-accent');
      btn.classList.remove('bg-white', 'text-ink', 'border-line');

      items.forEach(item => {
        const cat = item.dataset.category;
        const isFeatured = item.dataset.featured === 'true';
        const matches = filter === 'all' ? isFeatured : cat === filter;
        item.style.display = matches ? 'block' : 'none';
      });
    });
  });
</script>
