---
import BaseLayout from '../layouts/BaseLayout.astro';

const base = import.meta.env.BASE_URL;
---

<BaseLayout
  title="Contact Us — Mythri Waterproofing"
  description="Contact Mythri Waterproofing for a free site inspection and quote. Serving Hyderabad, Nalgonda, Vizag & Bangalore."
>

  <!-- Hero -->
  <section class="bg-brand text-white py-20 px-4 text-center">
    <p class="text-accent text-xs font-bold uppercase tracking-[2px] mb-3">Get In Touch</p>
    <h1 class="font-display text-4xl md:text-5xl font-extrabold mb-4">Contact Us</h1>
    <p class="text-white/60 text-lg max-w-2xl mx-auto">We'll get back to you within 24 hours with a free site visit booking.</p>
  </section>

  <section class="py-16 px-4 bg-bg-light">
    <div class="max-w-5xl mx-auto grid md:grid-cols-2 gap-12">

      <!-- Contact Info -->
      <div>
        <h2 class="font-display text-2xl font-extrabold text-ink mb-8">Contact Information</h2>
        <ul class="space-y-5">

          <li class="flex items-start gap-4">
            <div class="w-11 h-11 bg-accent/10 rounded-xl flex items-center justify-center shrink-0">
              <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            </div>
            <div>
              <div class="font-bold text-ink text-sm mb-1">Phone</div>
              <a href="tel:+919550667148" class="text-ink-muted hover:text-accent transition-colors block">+91 95506 67148</a>
              <a href="tel:+919052945434" class="text-ink-muted hover:text-accent transition-colors block">+91 90529 45434</a>
            </div>
          </li>

          <li class="flex items-start gap-4">
            <div class="w-11 h-11 bg-accent/10 rounded-xl flex items-center justify-center shrink-0">
              <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
            </div>
            <div>
              <div class="font-bold text-ink text-sm mb-1">Email</div>
              <a href="mailto:mythriwaterproofingworks@gmail.com" class="text-ink-muted hover:text-accent transition-colors">mythriwaterproofingworks@gmail.com</a>
            </div>
          </li>

          <li class="flex items-start gap-4">
            <div class="w-11 h-11 bg-accent/10 rounded-xl flex items-center justify-center shrink-0">
              <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
            </div>
            <div>
              <div class="font-bold text-ink text-sm mb-1">Office</div>
              <div class="text-ink-muted">Uppal, Hyderabad — 500039</div>
            </div>
          </li>

          <li class="flex items-start gap-4">
            <div class="w-11 h-11 bg-accent/10 rounded-xl flex items-center justify-center shrink-0">
              <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            </div>
            <div>
              <div class="font-bold text-ink text-sm mb-1">Working Hours</div>
              <div class="text-ink-muted">Mon – Sat: 9:00 AM – 5:00 PM</div>
            </div>
          </li>

        </ul>

        <!-- Free inspection callout -->
        <div class="mt-8 p-5 bg-white border border-accent/30 rounded-2xl shadow-sm">
          <div class="flex items-center gap-2 mb-2">
            <svg class="w-5 h-5 text-accent shrink-0" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            <div class="font-bold text-accent text-sm">Free Site Inspection</div>
          </div>
          <div class="text-ink-muted text-sm leading-relaxed">We offer free site visits for all enquiries. Our technician will assess your problem and provide a detailed quote — no obligations.</div>
        </div>

        <!-- WhatsApp shortcut -->
        <a href="https://wa.me/919550667148?text=Hi%2C%20I%20need%20waterproofing%20services" target="_blank" rel="noopener"
          class="mt-4 flex items-center justify-center gap-2 text-white font-bold px-6 py-3.5 rounded-[13px] w-full transition-colors"
          style="background:#25D366">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/></svg>
          Chat on WhatsApp
        </a>
      </div>

      <!-- Contact Form -->
      <div class="bg-white rounded-2xl border border-line shadow-sm p-8">
        <h2 class="font-display text-2xl font-extrabold text-ink mb-6">Send Us a Message</h2>
        <form
          action="https://formspree.io/f/mlgqperv"
          method="POST"
          class="space-y-5"
        >
          <div>
            <label class="block text-sm font-semibold text-ink mb-1.5" for="name">Full Name *</label>
            <input
              type="text" id="name" name="name" required
              placeholder="Your name"
              class="w-full border border-line rounded-xl px-4 py-3 text-ink placeholder:text-ink-subtle focus:outline-none focus:ring-2 focus:ring-accent focus:border-transparent transition"
            />
          </div>

          <div>
            <label class="block text-sm font-semibold text-ink mb-1.5" for="phone">Phone Number *</label>
            <input
              type="tel" id="phone" name="phone" required
              placeholder="+91 95506 67148"
              class="w-full border border-line rounded-xl px-4 py-3 text-ink placeholder:text-ink-subtle focus:outline-none focus:ring-2 focus:ring-accent focus:border-transparent transition"
            />
          </div>

          <div>
            <label class="block text-sm font-semibold text-ink mb-1.5" for="email">Email Address</label>
            <input
              type="email" id="email" name="email"
              placeholder="you@example.com"
              class="w-full border border-line rounded-xl px-4 py-3 text-ink placeholder:text-ink-subtle focus:outline-none focus:ring-2 focus:ring-accent focus:border-transparent transition"
            />
          </div>

          <div>
            <label class="block text-sm font-semibold text-ink mb-1.5" for="service">Service Required</label>
            <select
              id="service" name="service"
              class="w-full border border-line rounded-xl px-4 py-3 text-ink focus:outline-none focus:ring-2 focus:ring-accent focus:border-transparent transition"
            >
              <option value="">Select a service...</option>
              <option>Terrace / Roof Waterproofing</option>
              <option>Bathroom / Wet Area Waterproofing</option>
              <option>Wall / Facade Waterproofing</option>
              <option>Water Tank / Sump Waterproofing</option>
              <option>Basement Waterproofing</option>
              <option>Balcony & Podium Waterproofing</option>
              <option>Not sure — need inspection</option>
            </select>
          </div>

          <div>
            <label class="block text-sm font-semibold text-ink mb-1.5" for="message">Message</label>
            <textarea
              id="message" name="message" rows="4"
              placeholder="Describe your problem briefly..."
              class="w-full border border-line rounded-xl px-4 py-3 text-ink placeholder:text-ink-subtle focus:outline-none focus:ring-2 focus:ring-accent focus:border-transparent transition resize-none"
            ></textarea>
          </div>

          <button type="submit"
            class="w-full bg-accent hover:bg-accent-dark text-white font-bold py-4 rounded-[13px] text-base transition-colors shadow-[0_4px_14px_rgba(204,31,31,.25)]">
            Send Message
          </button>
        </form>
      </div>

    </div>
  </section>

</BaseLayout>
