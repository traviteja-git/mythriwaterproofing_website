---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact Us" description="Contact Mythri Waterproofing for a free inspection and quote. Serving Hyderabad and surrounding areas.">

  <!-- Hero -->
  <section class="bg-gradient-to-br from-primary to-primary-light text-white py-20 px-4 text-center">
    <h1 class="text-4xl md:text-5xl font-extrabold mb-4">Get in Touch</h1>
    <p class="text-blue-100 text-lg max-w-2xl mx-auto">We'll get back to you within 24 hours with a free site visit booking.</p>
  </section>

  <section class="py-20 px-4">
    <div class="max-w-5xl mx-auto grid md:grid-cols-2 gap-12">

      <!-- Contact Info -->
      <div>
        <h2 class="text-2xl font-extrabold text-primary mb-6">Contact Information</h2>
        <ul class="space-y-6">
          <li class="flex items-start gap-4">
            <div class="w-12 h-12 bg-primary/10 rounded-xl flex items-center justify-center text-2xl shrink-0">📞</div>
            <div>
              <div class="font-semibold text-primary">Phone</div>
              <a href="tel:+919876543210" class="text-gray-600 hover:text-accent">+91 98765 43210</a>
            </div>
          </li>
          <li class="flex items-start gap-4">
            <div class="w-12 h-12 bg-primary/10 rounded-xl flex items-center justify-center text-2xl shrink-0">📧</div>
            <div>
              <div class="font-semibold text-primary">Email</div>
              <a href="mailto:info@mythriwaterproofing.com" class="text-gray-600 hover:text-accent">info@mythriwaterproofing.com</a>
            </div>
          </li>
          <li class="flex items-start gap-4">
            <div class="w-12 h-12 bg-primary/10 rounded-xl flex items-center justify-center text-2xl shrink-0">📍</div>
            <div>
              <div class="font-semibold text-primary">Office</div>
              <div class="text-gray-600">Hyderabad, Telangana — 500001</div>
            </div>
          </li>
          <li class="flex items-start gap-4">
            <div class="w-12 h-12 bg-primary/10 rounded-xl flex items-center justify-center text-2xl shrink-0">⏰</div>
            <div>
              <div class="font-semibold text-primary">Working Hours</div>
              <div class="text-gray-600">Mon – Sat: 8:00 AM – 7:00 PM</div>
              <div class="text-gray-600">Sunday: By appointment</div>
            </div>
          </li>
        </ul>

        <div class="mt-8 p-4 bg-accent/10 border border-accent/30 rounded-xl">
          <div class="font-semibold text-accent mb-1">Free Site Inspection</div>
          <div class="text-gray-600 text-sm">We offer free site visits for all enquiries. Our technician will assess your problem and provide a detailed quotation — no obligations.</div>
        </div>
      </div>

      <!-- Contact Form -->
      <div>
        <h2 class="text-2xl font-extrabold text-primary mb-6">Send Us a Message</h2>
        <form
          action="https://formspree.io/f/YOUR_FORM_ID"
          method="POST"
          class="space-y-5"
        >
          <div>
            <label class="block text-sm font-semibold text-gray-700 mb-1" for="name">Full Name *</label>
            <input
              type="text"
              id="name"
              name="name"
              required
              placeholder="Your name"
              class="w-full border border-gray-300 rounded-xl px-4 py-3 focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent"
            />
          </div>

          <div>
            <label class="block text-sm font-semibold text-gray-700 mb-1" for="phone">Phone Number *</label>
            <input
              type="tel"
              id="phone"
              name="phone"
              required
              placeholder="+91 98765 43210"
              class="w-full border border-gray-300 rounded-xl px-4 py-3 focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent"
            />
          </div>

          <div>
            <label class="block text-sm font-semibold text-gray-700 mb-1" for="email">Email Address</label>
            <input
              type="email"
              id="email"
              name="email"
              placeholder="you@example.com"
              class="w-full border border-gray-300 rounded-xl px-4 py-3 focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent"
            />
          </div>

          <div>
            <label class="block text-sm font-semibold text-gray-700 mb-1" for="service">Service Required</label>
            <select
              id="service"
              name="service"
              class="w-full border border-gray-300 rounded-xl px-4 py-3 focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent"
            >
              <option value="">Select a service...</option>
              <option>Terrace / Roof Waterproofing</option>
              <option>Bathroom / Wet Area Waterproofing</option>
              <option>Wall / Facade Waterproofing</option>
              <option>Not sure — need inspection</option>
            </select>
          </div>

          <div>
            <label class="block text-sm font-semibold text-gray-700 mb-1" for="message">Message</label>
            <textarea
              id="message"
              name="message"
              rows="4"
              placeholder="Describe your problem briefly..."
              class="w-full border border-gray-300 rounded-xl px-4 py-3 focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent resize-none"
            ></textarea>
          </div>

          <button
            type="submit"
            class="w-full bg-accent hover:bg-accent-dark text-white font-bold py-4 rounded-xl text-lg transition-colors"
          >
            Send Message
          </button>
        </form>
      </div>
    </div>
  </section>

</BaseLayout>
