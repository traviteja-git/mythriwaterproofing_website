---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL;

const services = [
  {
    title: 'Terrace & Roof Waterproofing',
    href: `${base}services#terrace`,
    img: `${base}images/terrace/terrace-coating-1.jpg`,
  },
  {
    title: 'Bathroom Waterproofing',
    href: `${base}services#bathroom`,
    img: `${base}images/bathroom-epoxy/epoxy-1.jpg`,
  },
  {
    title: 'Brick Batting Works',
    href: `${base}services#bathroom`,
    img: `${base}images/brick-batting/brick-2.jpg`,
  },
  {
    title: 'Pressure Grouting',
    href: `${base}services#wall`,
    img: `${base}images/others/pressure-grouting.png`,
  },
  {
    title: 'Chemical Coating',
    href: `${base}services#terrace`,
    img: 'https://images.pexels.com/photos/6474490/pexels-photo-6474490.jpeg?auto=compress&cs=tinysrgb&w=600&h=400&fit=crop',
  },
  {
    title: 'Outside Wall Cracks',
    href: `${base}services#wall`,
    img: `${base}images/outside-cracks/crack-1.jpg`,
  },
  {
    title: 'Water Tanks & Sumps',
    href: `${base}services#tank`,
    img: `${base}images/others/water-tank.jpg`,
  },
  {
    title: 'Expansion Joints & Slabs',
    href: `${base}services#balcony`,
    img: `${base}images/expansion-joints/expansion-1.jpg`,
  },
];

const whyUs = [
  { icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>`, text: 'Free site inspection within Hyderabad' },
  { icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>`, text: 'Premium Dr. Fixit, Fosroc & Sika materials only' },
  { icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`, text: 'Trained, uniformed, background-verified technicians' },
  { icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>`, text: 'On-time delivery with minimal disruption' },
  { icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>`, text: 'Transparent pricing — no hidden charges' },
];

const testimonials = [
  { name: 'Ramesh Reddy', location: 'Gachibowli', text: 'Had terrace leakage for 3 years — two contractors failed. Mythri resolved it in 2 days. Excellent and very professional.' },
  { name: 'Sunitha Lakshmi', location: 'Kondapur', text: 'Bathroom was leaking into the hall. They waterproofed the entire wet area. No issues since then. Highly recommended!' },
  { name: 'Venkat Rao', location: 'Kukatpally', text: 'Top-class workmanship using Dr. Fixit products. Punctual, clean, and explained every step. Worth every rupee.' },
];
---

<BaseLayout title="Home" description="Mythri Waterproofing — Professional waterproofing for terrace, bathroom, walls and water tanks in Hyderabad. Free site inspection.">

  <!-- ① Hero -->
  <section class="bg-bg-light py-20 px-4">
    <div class="max-w-5xl mx-auto text-center">
      <!-- eyebrow -->
      <div class="inline-flex items-center gap-2 mb-5">
        <span class="w-5 h-0.5 bg-accent"></span>
        <span class="text-accent font-bold text-xs uppercase tracking-[1.6px]">Hyderabad's Trusted Waterproofing Experts</span>
        <span class="w-5 h-0.5 bg-accent"></span>
      </div>

      <h1 class="font-display font-extrabold text-ink leading-tight mb-5" style="font-size:clamp(36px,4.8vw,58px);letter-spacing:-1.4px">
        Stop Leaks. Protect Your Home.<br><span class="text-accent">For Good.</span>
      </h1>
      <p class="text-ink-muted text-lg mb-8 max-w-2xl mx-auto leading-relaxed">
        Professional waterproofing for terraces, bathrooms, walls & water tanks. 1000+ happy clients across Hyderabad, Nalgonda, Vizag & Bangalore. Free site inspection within Hyderabad.
      </p>

      <!-- Trust chips -->
      <div class="flex flex-wrap justify-center gap-3 mb-10">
        {['Free site visit (Hyderabad)', '20+ years experience', '1000+ projects done', 'Mon–Sat 9AM–5PM'].map(chip => (
          <span class="bg-white border border-line text-ink-mid font-semibold text-sm px-4 py-2 rounded-[9px] shadow-sm">
            {chip}
          </span>
        ))}
      </div>

      <!-- CTAs -->
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a href="tel:+919550667148"
          class="inline-flex items-center justify-center gap-2 bg-accent hover:bg-accent-dark text-white font-bold px-8 py-4 rounded-[13px] text-base transition-colors shadow-[0_12px_28px_rgba(220,31,38,.3)]">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          Call for Free Quote
        </a>
        <a href="https://wa.me/919550667148?text=Hi%2C%20I%20need%20waterproofing%20services" target="_blank" rel="noopener"
          class="inline-flex items-center justify-center gap-2 bg-white border-2 border-line hover:border-primary text-ink font-bold px-8 py-4 rounded-[13px] text-base transition-colors">
          <svg class="w-5 h-5 text-[#25D366]" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/></svg>
          WhatsApp Us
        </a>
      </div>
    </div>
  </section>

  <!-- ② Brand strip -->
  <section class="bg-brand py-5 px-4">
    <div class="max-w-5xl mx-auto flex flex-wrap justify-center items-center gap-6">
      <span class="text-white/40 text-xs uppercase tracking-[1.6px] font-bold">We use</span>
      {['Dr. Fixit', 'Fosroc', 'Sika', 'Asian Paints SmartCare', 'CICO'].map(b => (
        <span class="text-white/70 font-bold text-sm">{b}</span>
      ))}
    </div>
  </section>

  <!-- ③ Services -->
  <section class="py-20 px-4 bg-white">
    <div class="max-w-6xl mx-auto">
      <div class="mb-12 text-center">
        <div class="inline-flex items-center gap-2 mb-3">
          <span class="w-5 h-0.5 bg-accent"></span>
          <span class="text-accent font-bold text-xs uppercase tracking-[1.6px]">What We Do</span>
          <span class="w-5 h-0.5 bg-accent"></span>
        </div>
        <h2 class="font-display font-extrabold text-ink" style="font-size:clamp(28px,3.4vw,42px);letter-spacing:-1px">Our Services</h2>
      </div>
      <div class="grid grid-cols-2 sm:grid-cols-2 lg:grid-cols-4 gap-4">
        {services.map(({ title, href, img }) => (
          <a href={href}
            class="relative rounded-[16px] overflow-hidden aspect-square group shadow-sm hover:shadow-xl transition-all duration-200">
            <img src={img} alt={title} loading="lazy"
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" />
            <div class="absolute inset-0 bg-gradient-to-t from-black/75 via-black/20 to-transparent"></div>
            <div class="absolute bottom-0 left-0 right-0 p-4">
              <h3 class="font-display font-bold text-white text-sm leading-snug">{title}</h3>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ④ Why Choose Us -->
  <section class="py-20 px-4 bg-bg-warm">
    <div class="max-w-5xl mx-auto grid md:grid-cols-2 gap-14 items-center">
      <div>
        <div class="flex items-center gap-2 mb-3">
          <span class="w-5 h-0.5 bg-accent"></span>
          <span class="text-accent font-bold text-xs uppercase tracking-[1.6px]">Why Us</span>
        </div>
        <h2 class="font-display font-extrabold text-ink mb-5" style="font-size:clamp(28px,3.4vw,42px);letter-spacing:-1px">
          Why Hyderabad<br>Trusts Mythri
        </h2>
        <p class="text-ink-muted mb-8 leading-relaxed">We diagnose the root cause first — then apply the right solution. No shortcuts, no repeat visits.</p>
        <ul class="space-y-5">
          {whyUs.map(({ icon, text }) => (
            <li class="flex items-center gap-4">
              <div class="w-10 h-10 rounded-xl bg-white border border-line flex items-center justify-center text-accent shrink-0" set:html={icon}></div>
              <span class="text-ink-mid font-medium">{text}</span>
            </li>
          ))}
        </ul>
      </div>
      <!-- Stats -->
      <div class="grid grid-cols-2 gap-4">
        {[
          { stat: '1000+', label: 'Projects Completed', color: 'text-accent' },
          { stat: '20+',  label: 'Years Experience',   color: 'text-accent' },
          { stat: '100%', label: 'Client Satisfaction', color: 'text-accent' },
          { stat: 'Free', label: 'Inspection (Hyd)',    color: 'text-accent' },
        ].map(({ stat, label, color }) => (
          <div class="bg-white border border-line rounded-2xl p-6 text-center shadow-sm">
            <div class={`font-display font-extrabold text-4xl mb-1 ${color}`}>{stat}</div>
            <div class="text-ink-subtle text-sm">{label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ⑤ Testimonials -->
  <section class="py-20 px-4 bg-white">
    <div class="max-w-6xl mx-auto">
      <div class="mb-12 text-center">
        <div class="inline-flex items-center gap-2 mb-3">
          <span class="w-5 h-0.5 bg-accent"></span>
          <span class="text-accent font-bold text-xs uppercase tracking-[1.6px]">Reviews</span>
          <span class="w-5 h-0.5 bg-accent"></span>
        </div>
        <h2 class="font-display font-extrabold text-ink" style="font-size:clamp(28px,3.4vw,42px);letter-spacing:-1px">What Clients Say</h2>
        <p class="text-ink-muted mt-2">1000+ satisfied customers across Hyderabad, Nalgonda, Vizag & Bangalore</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {testimonials.map(({ name, location, text }) => (
          <div class="bg-bg-soft border border-line rounded-2xl p-7 flex flex-col gap-5">
            <div class="flex gap-1">
              {Array.from({ length: 5 }).map(() => (
                <svg class="w-4 h-4" fill="#FBB829" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
              ))}
            </div>
            <p class="text-ink-muted leading-relaxed flex-1">"{text}"</p>
            <div class="flex items-center gap-3">
              <div class="w-9 h-9 rounded-full bg-ink flex items-center justify-center text-white font-display font-bold text-sm shrink-0">
                {name[0]}
              </div>
              <div>
                <div class="font-bold text-ink text-sm">{name}</div>
                <div class="text-ink-subtle text-xs">{location}, Hyderabad</div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ⑥ Final CTA -->
  <section class="py-20 px-4 text-white text-center" style="background: linear-gradient(135deg, #1A1A1A 0%, #2D0A0A 100%)">
    <h2 class="font-display font-extrabold mb-3" style="font-size:clamp(28px,3.4vw,42px);letter-spacing:-1px">
      Ready to Fix Your Leakage?
    </h2>
    <p class="text-white/80 text-lg mb-10 max-w-xl mx-auto">Free site inspection. No obligations. Call or WhatsApp us right now.</p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a href="tel:+919550667148"
        class="inline-flex items-center justify-center gap-2 bg-white text-accent hover:bg-gray-100 font-bold px-8 py-4 rounded-[13px] text-lg transition-colors">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        +91 95506 67148
      </a>
      <a href="https://wa.me/919550667148?text=Hi%2C%20I%20need%20waterproofing%20services" target="_blank" rel="noopener"
        class="inline-flex items-center justify-center gap-2 text-white font-bold px-8 py-4 rounded-[13px] text-lg transition-colors"
        style="background:#25D366">
        <svg class="w-5 h-5" fill="white" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/></svg>
        WhatsApp Us
      </a>
    </div>
  </section>

</BaseLayout>
